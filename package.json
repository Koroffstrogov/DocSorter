{
  "name": "docsorter-local",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first desktop document sorter for Windows.",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-renderer-assets.mjs",
    "dev": "npm run build && node scripts/run-electron.mjs",
    "start": "npm run build && node scripts/run-electron.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "electron",
    "documents",
    "local-first"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "electron": "^42.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "pdfjs-dist": "^6.0.227"
  }
}
